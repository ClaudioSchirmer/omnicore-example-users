{
  "index_patterns": ["omnicore-logs*"],
  "template": {
    "mappings": {
      "dynamic_templates": [
        {
          "payload_objects": {
            "match_mapping_type": "object",
            "mapping": { "type": "flattened" }
          }
        },
        {
          "strings_as_keyword": {
            "match_mapping_type": "string",
            "mapping": { "type": "keyword", "ignore_above": 8192 }
          }
        }
      ]
    }
  }
}

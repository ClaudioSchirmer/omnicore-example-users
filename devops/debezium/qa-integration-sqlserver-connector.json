{
  "name": "qa-integration-sqlserver-connector",
  "config": {
    "connector.class": "io.debezium.connector.sqlserver.SqlServerConnector",
    "tasks.max": "1",

    "database.hostname": "${QA_MSSQL_HOST}",
    "database.port": "${QA_MSSQL_PORT}",
    "database.user": "sa",
    "database.password": "OmnicoreQA!2026",
    "database.names": "users_db",
    "database.encrypt": "false",
    "topic.prefix": "omnicore_users_qa_mssql",

    "table.include.list": "dbo.integration_events",
    "tombstones.on.delete": "false",
    "snapshot.mode": "no_data",
    "poll.interval.ms": "100",

    "schema.history.internal.kafka.bootstrap.servers": "kafka-sqlserver:9092",
    "schema.history.internal.kafka.topic": "schema-history.sqlserver.qa-integration",

    "transforms": "outbox",
    "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
    "transforms.outbox.table.field.event.id": "event_id",
    "transforms.outbox.table.field.event.key": "aggregate_id",
    "transforms.outbox.table.field.event.type": "event_type",
    "transforms.outbox.table.field.event.payload": "payload",
    "transforms.outbox.route.by.field": "event_type",
    "transforms.outbox.route.topic.replacement": "qa.integration.events.sqlserver",
    "transforms.outbox.table.fields.additional.placement": "event_type:header,aggregate_type:header,traceparent:header:traceparent",
    "transforms.outbox.table.expand.json.payload": "false",

    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter.schemas.enable": "false"
  }
}

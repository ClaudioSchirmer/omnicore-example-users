{
  "realm": "omnicore-test",
  "enabled": true,
  "displayName": "OmniCore Test Realm",
  "accessTokenLifespan": 60,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      {"name": "user", "description": "Standard user role"},
      {"name": "admin", "description": "Administrative role"}
    ]
  },
  "clients": [
    {
      "clientId": "omnicore-users-client",
      "name": "OmniCore Users Service Client",
      "enabled": true,
      "publicClient": false,
      "secret": "test-secret-please-change",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [],
      "webOrigins": [],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "60"
      },
      "protocolMappers": [
        {
          "name": "audience-omnicore-users-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "omnicore-users-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "permissions-from-user-attribute",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "permissions",
            "claim.name": "permissions",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "multivalued": "true",
            "aggregate.attrs": "false"
          }
        }
      ]
    },
    {
      "clientId": "wrong-aud-client",
      "name": "Client whose tokens target a different service (used to exercise audience rejection)",
      "enabled": true,
      "publicClient": false,
      "secret": "wrong-aud-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [],
      "webOrigins": [],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "audience-some-other-service",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "some-other-service",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@omnicore.test",
      "firstName": "Alice",
      "lastName": "Tester",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {"type": "password", "value": "alice123", "temporary": false}
      ],
      "realmRoles": ["user"],
      "attributes": {
        "permissions": ["users:read", "users:write", "users:archive"]
      }
    },
    {
      "username": "bob",
      "email": "bob@omnicore.test",
      "firstName": "Bob",
      "lastName": "Tester",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {"type": "password", "value": "bob123", "temporary": false}
      ],
      "realmRoles": ["admin", "user"],
      "attributes": {
        "permissions": ["*:*"]
      }
    },
    {
      "username": "noperm",
      "email": "noperm@omnicore.test",
      "firstName": "No",
      "lastName": "Perm",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {"type": "password", "value": "noperm123", "temporary": false}
      ],
      "realmRoles": ["user"]
    }
  ],
  "components": {
    "org.keycloak.keys.KeyProvider": [
      {
        "name": "rsa-pinned",
        "providerId": "rsa",
        "subComponents": {},
        "config": {
          "priority": ["100"],
          "enabled": ["true"],
          "active": ["true"],
          "algorithm": ["RS256"],
          "privateKey": [""],
          "certificate": [""]
        }
      }
    ]
  }
}
